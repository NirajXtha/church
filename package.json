{
  "name": "church-presenter",
  "version": "1.0.13",
  "description": "Church Presentation Application - Bible verses and song lyrics display",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npx electron-builder",
    "build:win": "npx electron-builder --win",
    "build:portable": "npx electron-builder --win --x64",
    "build:dist": "npx electron-builder --win --x64"
  },
  "build": {
    "appId": "church.presenter.app",
    "productName": "Church Presenter",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "bible.sqlite",
        "to": "bible.sqlite"
      },
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "app-update.yml",
        "to": "app-update.yml"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "NirajXtha",
      "repo": "church",
      "releaseType": "release"
    },
    "win": {
      "artifactName": "Church-Presenter.${ext}",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Setup.${ext}",
      "warningsAsErrors": false
    }
  },
  "keywords": [
    "church",
    "presentation",
    "bible",
    "song",
    "lyrics"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2"
  }
}
